# DeepSeek (OpenAI-compatible API)
DEEPSEEK_API_KEY="sk-504d303f10fc4a3eb1ac43ad252580f0"
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Hugging Face model id (not a disk path). Example:
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Local folder (optional). Relative paths are from the RepairBot repo root, not backend/.
# EMBEDDING_LOCAL_DIR=models/all-MiniLM-L6-v2

# Hugging Face download (if progress stays at 0%: raise timeout, use mirror, or pip install hf_transfer)
# HF_HUB_DOWNLOAD_TIMEOUT=600
# Optional mirror in some regions: https://hf-mirror.com
# HF_ENDPOINT=https://hf-mirror.com
# Faster downloads after: pip install hf_transfer
# HF_HUB_ENABLE_HF_TRANSFER=1

# Chroma persistence (relative to repo root or absolute)
CHROMA_PERSIST_DIR=./backend/data/chroma_db

# RAG
RAG_TOP_K=5

# CORS (comma-separated origins for dev)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
